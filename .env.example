NODE_ENV=development
PORT=8080
PUBLIC_BASE_URL=http://localhost:8080
LOG_LEVEL=info

# Comma-separated list of allowed group codes (4-char) and area codes (2-char).
# Production tenant model: one Salesforce org, allow-list driven from this env var.
# Phase 4 may replace this with a startup query against Salesforce.
ALLOWED_GROUP_CODES=EKWG,WMID

# Comma-separated list of long-lived bearer tokens (sha256 hex) issued to
# consumers (NGX-Ramblers, MailMan, etc.). Each token authorises every group
# in ALLOWED_GROUP_CODES. Tokens are compared against this list at request
# time; no per-tenant scoping in production (the org is the tenant boundary).
API_TOKEN_HASHES=

# Salesforce connection (optional - server boots without these and the
# /healthz/salesforce endpoint reports NOT_CONFIGURED). Phase 4 fills these
# in from HQ's connected app:
SF_LOGIN_URL=https://login.salesforce.com
SF_CLIENT_ID=
SF_USERNAME=
SF_JWT_PRIVATE_KEY_PATH=
