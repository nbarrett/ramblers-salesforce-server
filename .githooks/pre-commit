#!/usr/bin/env bash

set -e

ROOT="$(git rev-parse --show-toplevel)"
CHANGED=$(git diff --cached --name-only --diff-filter=ACM)

TS_FILES=$(echo "$CHANGED" | grep -E '^typescript/(src|scripts)/.*\.ts$' | sed 's#^typescript/##' || true)
if [ -n "$TS_FILES" ]; then
  echo "Linting staged TypeScript..."
  (cd "$ROOT/typescript" && pnpm exec eslint $TS_FILES)
  echo "TypeScript lint passed!"
fi

PY_FILES=$(echo "$CHANGED" | grep -E '^python/.*\.py$' || true)
if [ -n "$PY_FILES" ]; then
  if [ -x "$ROOT/python/.venv/bin/ruff" ]; then
    RUFF="$ROOT/python/.venv/bin/ruff"
  elif command -v ruff >/dev/null 2>&1; then
    RUFF="ruff"
  else
    RUFF=""
  fi
  if [ -n "$RUFF" ]; then
    echo "Linting staged Python..."
    (cd "$ROOT/python" && "$RUFF" check .)
    echo "Python lint passed!"
  else
    echo "ruff not found - skipping Python lint (create python/.venv or install ruff)"
  fi
fi
