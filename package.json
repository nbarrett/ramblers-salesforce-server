{
  "name": "ramblers-salesforce-server",
  "version": "0.1.0",
  "private": true,
  "description": "Production server for the Ramblers Salesforce API. Consumes @ramblers/sf-contract for the wire format. Salesforce adapter scaffolded - methods throw 501 until Phase 4 (Ramblers HQ fill in SOQL queries and field mappers).",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@10.11.0",
  "scripts": {
    "build": "esbuild src/server.ts --bundle --platform=node --target=node20 --format=esm --outfile=dist/server.js --packages=external --sourcemap",
    "start": "node dist/server.js",
    "dev": "tsx watch src/server.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint 'src/**/*.ts'",
    "test": "vitest run --passWithNoTests",
    "deploy": "flyctl deploy",
    "setup:hooks": "bash tools/setup-git-hooks.sh"
  },
  "dependencies": {
    "@ramblers/sf-contract": "github:nbarrett/ramblers-salesforce-contract#v0.2.0",
    "express": "4.22.1",
    "jsforce": "3.10.4",
    "pino": "9.14.0",
    "pino-http": "10.5.0",
    "swagger-ui-express": "5.0.1",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@types/express": "4.17.25",
    "@types/node": "20.19.39",
    "@types/swagger-ui-express": "4.1.8",
    "esbuild": "0.28.0",
    "eslint": "9.39.4",
    "jiti": "2.6.0",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.59.1",
    "vitest": "2.1.9"
  }
}
